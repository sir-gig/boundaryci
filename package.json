{
  "name": "boundaryci",
  "version": "0.4.0",
  "description": "Continuous tenant-isolation testing for Supabase and multi-tenant SaaS.",
  "license": "MIT",
  "author": "Ryan",
  "files": [
    "dist",
    "EULA.md",
    "PRIVACY.md",
    "SUPPORT.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sir-gig/boundaryci.git"
  },
  "homepage": "https://boundaryci.com/",
  "bugs": {
    "url": "https://github.com/sir-gig/boundaryci/issues"
  },
  "keywords": [
    "supabase",
    "postgresql",
    "row-level-security",
    "tenant-isolation",
    "security",
    "github-action"
  ],
  "type": "module",
  "bin": {
    "boundaryci": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --dir test",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "scan:example": "tsx src/cli.ts scan examples/vulnerable-supabase --fail-on none",
    "prepack": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
